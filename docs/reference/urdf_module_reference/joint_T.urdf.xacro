<?xml version="1.0"?>
<robot name="joint_T" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:macro name="joint_T" params="moduleID angle *mimic">
        <!-- import components of gazebo -->
        <xacro:include filename="$(find m-rex)/urdf/gazebo_config.xacro" />
        
        <gazebo>
            <plugin name="gazebo_ros_joint_state_publisher_${moduleID}"
                filename="libgazebo_ros_joint_state_publisher.so">
                <update_rate>20</update_rate>
                <joint_name>proximalPart_to_distalPart_${moduleID}</joint_name>
            </plugin>
        </gazebo>

        <link name="connector_${moduleID}A">
            <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <material name="">
                <color rgba="1 1 1 1" />
            </material>
            </visual>
        </link>

        <joint name="connectorA_to_proximalPart_${moduleID}" type="fixed">
            <origin xyz="0 0 0" rpy="${-pi} 0 0" />
            <parent link="connector_${moduleID}A" />
            <child link="proximalPart_${moduleID}" />
        </joint>

        <link name="proximalPart_${moduleID}">
            <visual>
            <origin xyz="0 0 ${link_length}" rpy="0 0 0" />
            <geometry>
                <cylinder length="${link_length*2}" radius="${link_radius}"/>
            </geometry>
            <material name="white" />
            </visual>
            <collision>
                <geometry>
                    <box size="${box_x} ${box_y} ${box_z-0.003}" />
                </geometry>
            </collision>
            <inertial>
                <mass value="${link_mass*2}" />
                <inertia ixx="1e-9" ixy="0.0" ixz="0.0" iyy="1e-9" iyz="0.0" izz="1e-9" />
            </inertial>
        </link>

        <link name="connector_${moduleID}C">
            <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <material name="">
                <color rgba="1 1 1 1" />
            </material>
            </visual>
        </link>

        <joint name="proximalPart_to_connectorC_${moduleID}" type="fixed">
            <origin xyz="0 0 ${link_length*2}" rpy="0 0 0" />
            <parent link="proximalPart_${moduleID}" />
            <child link="connector_${moduleID}C" />
        </joint>

        <link name="distalPart_${moduleID}">
            <visual>
            <origin xyz="0 0 ${link_length/2}" rpy="0 0 0" />
            <geometry>
                <cylinder length="${link_length}" radius="${link_radius}"/>
            </geometry>
            <material name="white" />
            </visual>
            <collision>
                <geometry>
                    <box size="${box_x} ${box_y} ${box_z-0.003}" />
                </geometry>
            </collision>
            <inertial>
                <mass value="${link_mass}" />
                <inertia ixx="1e-9" ixy="0.0" ixz="0.0" iyy="1e-9" iyz="0.0" izz="1e-9" />
            </inertial>
        </link>

        <joint name="proximalPart_to_distalPart_${moduleID}" type="revolute">
            <origin xyz="0 0 ${link_length}" rpy="${angle} 0 0" />
            <parent link="proximalPart_${moduleID}" />
            <child link="distalPart_${moduleID}" />
            <axis xyz="1 0 0" />
            <limit lower="${-pi}" upper="${pi}" effort="0" velocity="0" />
            <xacro:insert_block name="mimic" />
        </joint>
        <joint name="proximalPart_to_jointLVisual_${moduleID}" type="fixed">
            <origin xyz="0 0 ${link_length}" rpy="0 0 0" />
            <parent link="proximalPart_${moduleID}" />
            <child link="jointLVisual_${moduleID}" />
        </joint>

        <link name="jointLVisual_${moduleID}">
            <visual>
            <origin xyz="0 0 0" rpy="0 1.57 0" />
            <geometry>
                <cylinder length="${jointVisual_length}" radius="${jointVisual_radius}"/>
            </geometry>
            <material name="yellow" />
            </visual>
        </link>

        <link name="connector_${moduleID}B">
            <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <material name="">
                <color rgba="1 1 1 1" />
            </material>
            </visual>
        </link>

        <joint name="distalPart_to_connectorB_${moduleID}" type="fixed">
            <origin xyz="0 0 ${link_length}" rpy="0 0 0" />
            <parent link="distalPart_${moduleID}" />
            <child link="connector_${moduleID}B" />
        </joint>

    </xacro:macro>

</robot>