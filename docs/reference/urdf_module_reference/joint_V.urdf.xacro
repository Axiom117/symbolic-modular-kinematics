<?xml version="1.0"?>
<robot name="joint_V" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:macro name="joint_V" params="moduleID *mimic1 *mimic2">
        <!-- import components of gazebo -->
        <xacro:include filename="$(find m-rex)/urdf/gazebo_config.xacro" />
        
        <!-- joint state publisher -->
        <gazebo>
            <plugin name="gazebo_ros_joint_state_publisher_${moduleID}"
                filename="libgazebo_ros_joint_state_publisher.so">
                <update_rate>20</update_rate>
                <joint_name>proximalPart_to_virtualLink_${moduleID}</joint_name>
                <joint_name>virtualLink_to_distalPart_${moduleID}</joint_name>
            </plugin>
        </gazebo>

        <!-- joint controller -->
        <gazebo>
            <plugin name="gazebo_ros_joint_pose_trajectory_${moduleID}"
                filename="libgazebo_ros_joint_pose_trajectory.so">
                <update_rate>20</update_rate>
            </plugin>
        </gazebo>

        <link name="inputConnector_${moduleID}">
            <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <material name="">
                <color rgba="1 1 1 1" />
            </material>
            </visual>
        </link>

        <joint name="inputConnector_to_proximalPart_${moduleID}" type="fixed">
            <origin xyz="0 0 0" rpy="0 0 0" />
            <parent link="inputConnector_${moduleID}" />
            <child link="proximalPart_${moduleID}" />
        </joint>

        <link name="proximalPart_${moduleID}">
            <visual>
            <origin xyz="0 0 ${link_length/2}" rpy="0 0 0" />
            <geometry>
                <cylinder length="${link_length}" radius="${link_radius}"/>
            </geometry>
            <material name="white" />
            </visual>
            <collision>
                <geometry>
                    <box size="${box_x} ${box_y} ${box_z-0.003}" />
                </geometry>
            </collision>
            <inertial>
                <mass value="${link_mass}" />
                <inertia ixx="1e-9" ixy="0.0" ixz="0.0" iyy="1e-9" iyz="0.0" izz="1e-9" />
            </inertial>
        </link>

        <link name="distalPart_${moduleID}">
            <visual>
            <origin xyz="0 0 ${link_length/2}" rpy="0 0 0" />
            <geometry>
                <cylinder length="${link_length}" radius="${link_radius}"/>
            </geometry>
            <material name="white" />
            </visual>
            <collision>
                <geometry>
                    <box size="${box_x} ${box_y} ${box_z-0.003}" />
                </geometry>
            </collision>
            <inertial>
                <mass value="${link_mass}" />
                <inertia ixx="1e-9" ixy="0.0" ixz="0.0" iyy="1e-9" iyz="0.0" izz="1e-9" />
            </inertial>
        </link>

        <joint name="proximalPart_to_virtualLink_${moduleID}" type="revolute">
            <origin xyz="0 0 ${link_length}" rpy="0 0 0" />
            <parent link="proximalPart_${moduleID}" />
            <child link="virtualLink_${moduleID}" />
            <axis xyz="1 0 0" />
            <limit lower="-3.14" upper="3.14" effort="0" velocity="0" />
            <xacro:insert_block name="mimic1" />
        </joint>

        <link name="virtualLink_${moduleID}">
            <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <material name="">
                <color rgba="1 1 1 1" />
            </material>
            </visual>
            <inertial>
                <mass value="${link_mass}" />
                <inertia ixx="1e-9" ixy="0.0" ixz="0.0" iyy="1e-9" iyz="0.0" izz="1e-9" />
            </inertial>
        </link>

        <joint name="virtualLink_to_distalPart_${moduleID}" type="revolute">
            <origin xyz="0 0 0" rpy="0 0 0" />
            <parent link="virtualLink_${moduleID}" />
            <child link="distalPart_${moduleID}" />
            <axis xyz="0 1 0" />
            <limit lower="-3.14" upper="3.14" effort="0" velocity="0" />
            <xacro:insert_block name="mimic2" />
        </joint>

        <joint name="proximal_to_pitchVisual_${moduleID}" type="fixed">
            <origin xyz="0 0 ${link_length}" rpy="0 0 0" />
            <parent link="proximalPart_${moduleID}" />
            <child link="pitchVisual_${moduleID}" />
        </joint>

        <link name="pitchVisual_${moduleID}">
            <visual>
            <origin xyz="0 0 0" rpy="0 1.57 0" />
            <geometry>
                <cylinder length="0.003" radius="0.0015"/>
            </geometry>
            <material name="green" />
            </visual>
        </link>

        <joint name="virtualLink_to_yawVisual_${moduleID}" type="fixed">
            <origin xyz="0 0 0" rpy="0 0 0" />
            <parent link="virtualLink_${moduleID}" />
            <child link="yawVisual_${moduleID}" />
        </joint>

        <link name="yawVisual_${moduleID}">
            <visual>
            <origin xyz="0 0 0" rpy="1.57 0 0" />
            <geometry>
                <cylinder length="0.003" radius="0.0015"/>
            </geometry>
            <material name="green" />
            </visual>
        </link>

        <link name="outputConnector_${moduleID}">
            <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <material name="">
                <color rgba="1 1 1 1" />
            </material>
            </visual>
        </link>

        <joint name="distalPart_to_outputConnector_${moduleID}" type="fixed">
            <origin xyz="0 0 ${link_length}" rpy="0 0 0" />
            <parent link="distalPart_${moduleID}" />
            <child link="outputConnector_${moduleID}" />
        </joint>

    </xacro:macro>

</robot>